APP_ENV=development
APP_PORT=8000
MODEL_VERSION=lfm2.5-vl-450m-prompted
MODEL_ENDPOINT=
MODEL_HTTP_ENABLED=
MODEL_API_KEY=
MODEL_PROVIDER=atlas_json_http
# for a shared OpenAI-compatible multimodal candidate lane, including vLLM behind
# the endpoint, use:
# MODEL_VERSION=LiquidAI/LFM2.5-VL-450M
# MODEL_ENDPOINT=https://your-vllm-or-liquid-host/v1/chat/completions
# MODEL_PROVIDER=openai_chat_completions_http
# for a local Apple Silicon bridge backed by MLX, use:
# MODEL_VERSION=LiquidAI/LFM2.5-VL-450M-MLX-4bit
# MODEL_ENDPOINT=http://127.0.0.1:8014/v1/chat/completions
# MODEL_PROVIDER=openai_chat_completions_http
AGENT_MODEL_VERSION=lfm2.5-1.2b-instruct
AGENT_ENDPOINT=
AGENT_HTTP_ENABLED=
AGENT_API_KEY=
AGENT_PROVIDER=atlas_json_http
# candidate + planner both run through the same thin Python model gateway;
# keep provider/env split, but do not treat this repo like a custom ML framework
# for Liquid-served text planning, use:
# AGENT_MODEL_VERSION=LiquidAI/LFM2.5-1.2B-Instruct
# AGENT_ENDPOINT=https://your-liquid-host/v1/chat/completions
# AGENT_PROVIDER=openai_chat_completions_http
# for local Ollama + Liquid GGUF, use:
# AGENT_MODEL_VERSION=hf.co/LiquidAI/LFM2.5-1.2B-Instruct-GGUF
# AGENT_ENDPOINT=http://127.0.0.1:11434/v1/chat/completions
# AGENT_PROVIDER=openai_chat_completions_http
SIMSAT_CURRENT_ENDPOINT=
SIMSAT_BASELINE_ENDPOINT=
SIMSAT_CURRENT_HTTP_ENABLED=
SIMSAT_BASELINE_HTTP_ENABLED=
# local SimSat defaults after `docker compose up` in the official SimSat repo:
# SIMSAT_CURRENT_ENDPOINT=http://localhost:9005/data/current/image/sentinel
# SIMSAT_BASELINE_ENDPOINT=http://localhost:9005/data/image/sentinel
MAPBOX_TOKEN=
MAPBOX_CONTEXT_ENABLED=true
WATCHLIST_PATH=
LEAD_REGISTRY_PATH=
