APP_ENV=development
APP_PORT=8000
PRODUCTION_DEMO_MODE=false
MODEL_VERSION=lfm2.5-vl-450m-prompted
MODEL_ENDPOINT=
MODEL_HTTP_ENABLED=
MODEL_API_KEY=
MODEL_PROVIDER=atlas_json_http
# for a shared OpenAI-compatible multimodal candidate lane, including vLLM behind
# the endpoint, use:
# MODEL_VERSION=LiquidAI/LFM2.5-VL-450M
# MODEL_ENDPOINT=https://your-vllm-or-liquid-host/v1/chat/completions
# MODEL_PROVIDER=openai_chat_completions_http
# for a local Apple Silicon bridge backed by MLX, use:
# MODEL_VERSION=LiquidAI/LFM2.5-VL-450M-MLX-4bit
# MODEL_ENDPOINT=http://127.0.0.1:8014/v1/chat/completions
# MODEL_PROVIDER=openai_chat_completions_http
AGENT_MODEL_VERSION=hf.co/LiquidAI/LFM2.5-1.2B-Instruct-GGUF:latest
AGENT_ENDPOINT=http://127.0.0.1:11434/v1/chat/completions
AGENT_HTTP_ENABLED=true
AGENT_API_KEY=
AGENT_PROVIDER=openai_chat_completions_http
AGENT_TIMEOUT_SECONDS=15
# candidate + planner both run through the same thin Python model gateway;
# keep provider/env split, but do not treat this repo like a custom ML framework
# for a dedicated Liquid/vLLM endpoint instead, use:
# AGENT_MODEL_VERSION=LiquidAI/LFM2.5-1.2B-Instruct
# AGENT_ENDPOINT=https://your-liquid-host/v1/chat/completions
# AGENT_PROVIDER=openai_chat_completions_http
SAM3_MODEL_VERSION=facebook/sam3
SAM3_ENDPOINT=http://127.0.0.1:8787/sam3
SAM3_HTTP_ENABLED=false
SAM3_REQUIRED=false
SAM3_API_KEY=
SAM3_BRIDGE_BACKEND=transformers
SAM3_ALLOW_CPU=true
# SAM stays outside the runtime authority path. Keep this off unless running
# high-resolution SAM eval experiments separately.
ANALYST_MODEL_VERSION=LiquidAI/LFM2.5-VL-450M
ANALYST_ENDPOINT=http://127.0.0.1:8014/v1/chat/completions
ANALYST_HTTP_ENABLED=true
ANALYST_API_KEY=
ANALYST_PROVIDER=openai_chat_completions_http
ANALYST_TIMEOUT_SECONDS=60
ANALYST_ADAPTER_REF=ChrisRPL/blackline-atlas-lfm25-vl-sft-hf-corpus-full-v1b-adapter
# Optional paired-image Liquid VLM analyst. It summarizes civilian before/after
# disruption evidence behind source-led and SAM3 guardrails; it is not alert authority.
# Adapter-capable local bridge:
# python3 training/scripts/serve_liquid_vl_openai.py --port 8014 --backend transformers --model-id LiquidAI/LFM2.5-VL-450M --adapter-ref ChrisRPL/blackline-atlas-lfm25-vl-sft-hf-corpus-full-v1b-adapter
# ANALYST_MODEL_VERSION=LiquidAI/LFM2.5-VL-450M
# ANALYST_ENDPOINT=http://127.0.0.1:8014/v1/chat/completions
# ANALYST_HTTP_ENABLED=true
# ANALYST_PROVIDER=openai_chat_completions_http
# ANALYST_TIMEOUT_SECONDS=60
# MLX base-only bridge, when Metal is available but PEFT adapter loading is not needed:
# python3 training/scripts/serve_liquid_vl_openai.py --port 8014 --model-id LiquidAI/LFM2.5-VL-450M-MLX-4bit
# ANALYST_MODEL_VERSION=LiquidAI/LFM2.5-VL-450M-MLX-4bit
# ANALYST_ENDPOINT=http://127.0.0.1:8014/v1/chat/completions
# ANALYST_HTTP_ENABLED=true
# ANALYST_PROVIDER=openai_chat_completions_http
# Live runtime expects local SimSat to be running on :9005. If it is not
# reachable, the UI must say so instead of presenting cached frames as live.
SIMSAT_REQUIRED=true
SIMSAT_CURRENT_ENDPOINT=http://localhost:9005/data/current/image/sentinel
SIMSAT_BASELINE_ENDPOINT=http://localhost:9005/data/image/sentinel
SIMSAT_CURRENT_HTTP_ENABLED=true
SIMSAT_BASELINE_HTTP_ENABLED=true
MAPBOX_TOKEN=
MAPBOX_CONTEXT_ENABLED=true
WATCHLIST_PATH=
LEAD_REGISTRY_PATH=var/live_leads.json
GDELT_API_KEY=
GDELT_CLOUD_API_KEY=
# GDELT Cloud v2 Events is the preferred live lead provider when a key is set.
# Auto refresh uses GDELT Cloud first, then falls back to public GDELT Project.
# By default Cloud queries global conflict events in one request. Pass
# --gdelt-cloud-countries when you need a specific country shortlist.
# ACLED support exists but is disabled by default because API account access
# must be confirmed separately. GDELT Cloud is the current default live path.
# Use ACLED_ACCESS_TOKEN for a short-lived token, or ACLED_USERNAME/PASSWORD to
# let the refresh command request a token via OAuth, only after access works.
ACLED_ACCESS_TOKEN=
ACLED_USERNAME=
ACLED_PASSWORD=
# Keep disabled unless the account can read /api/acled/read.
ACLED_LEAD_ENABLED=false
# Refresh live conflict/disruption markers before starting the app:
# python3 -m app.services.lead_registry_refresh --source-mode gdelt_cloud --output-path var/live_leads.json
# Fallback without GDELT Cloud credentials:
# python3 -m app.services.lead_registry_refresh --source-mode gdelt --output-path var/live_leads.json
